DATABASE_URL=postgres://postgres:postgres@localhost:5432/experience_memory
TOKEN_ENCRYPTION_KEY=

# HTTP transport for PlayMCP in KC.
PORT=8000
MCP_HTTP_PATH=/mcp
HEALTH_PATH=/healthz
GOOGLE_OAUTH_CALLBACK_PATH=/oauth/google/callback
EXPERIENCE_MEMORY_DATA_DIR=/tmp/experience-memory

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DRIVE_ROOT_FOLDER_NAME=Experience Memories

# PlayMCP OAuth registration values:
# Authorization Endpoint URL: https://accounts.google.com/o/oauth2/v2/auth
# Token Endpoint URL: https://oauth2.googleapis.com/token
# Scope: openid email profile https://www.googleapis.com/auth/drive.file

# Optional single-user fallback. Do not use these for public multi-user deployment.
# GOOGLE_REDIRECT_URI=http://localhost:53682/oauth2callback
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_DRIVE_ROOT_FOLDER_ID=
# GOOGLE_ACCESS_TOKEN=

# Optional multi-user actor mode.
# EXPERIENCE_MEMORY_ACTOR_PROVIDER=kakao
# EXPERIENCE_MEMORY_ACTOR_ID=
# EXPERIENCE_MEMORY_ACTOR_HEADER=x-playmcp-user-id
# EXPERIENCE_MEMORY_DEFAULT_ACTOR_ID=playmcp-demo
