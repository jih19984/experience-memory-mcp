{
  "name": "experience-memory-mcp",
  "version": "0.1.0",
  "description": "MCP server that stores photo or text experience memories and retrieves them by natural language.",
  "type": "module",
  "bin": {
    "experience-memory-mcp": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:stdio": "MCP_TRANSPORT=stdio tsx src/index.ts",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "start:stdio": "MCP_TRANSPORT=stdio node dist/index.js",
    "db:init": "tsx src/cli/database.ts init",
    "db:check": "tsx src/cli/database.ts check",
    "google:auth": "tsx src/cli/googleAuth.ts",
    "test": "vitest run tests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "mcp",
    "memory",
    "google-drive",
    "postgresql"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/server": "2.0.0-beta.2",
    "dotenv": "17.2.3",
    "googleapis": "173.0.0",
    "pg": "8.22.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/pg": "8.15.6",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
